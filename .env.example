# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable__your-anon-key-here

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com → API Keys
# ⚠️  NEVER expose this key client-side. Used only in serverless API routes.
GROQ_API_KEY=gsk_...

# ── PayFast (South African payment gateway) ────────────────────────────────────
# Get from: https://www.payfast.co.za/account
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
# Use 'sandbox' for testing, 'live' for production
PAYFAST_ENV=sandbox

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3005
